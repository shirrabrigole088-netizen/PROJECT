<Window x:Class="BrigoleWpsApplicationProject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Watchlist" Height="500" Width="850"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        ResizeMode="NoResize">

    <Grid Margin="10">
            <Grid.ColumnDefinitions>
        <ColumnDefinition Width="2*" />
        <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- LEFT PANEL -->
    <Border Grid.Column="0" CornerRadius="10" Padding="10"
            Background="LightBlue"
            Margin="5"
            BorderBrush="Gray" BorderThickness="1">

        <StackPanel>
            <TextBlock Text="Watchlist"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="5"
                       Foreground="White"/>

            <DataGrid x:Name="dataGrid"
                      AutoGenerateColumns="False"
                      Height="320"
                      Margin="5"
                      RowHeight="30"
                      FontSize="13"
                      Background="White"
                      Foreground="LightBlue"
                      RowBackground="White"
                      AlternatingRowBackground="LightBlue"
                      GridLinesVisibility="None"
                      HeadersVisibility="Column"
                      SelectionChanged="dataGrid_SelectionChanged">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="LightBlue"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*" />
                    <DataGridTextColumn Header="Genre" Binding="{Binding Genre}" Width="*" />
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*" />
                    <DataGridTextColumn Header="Rating" Binding="{Binding Rating}" Width="Auto" />
                </DataGrid.Columns>
            </DataGrid>

            <Button x:Name="btnDeleteData"
                    Content="🗑 DELETE"
                    Height="45"
                    Margin="5"
                    FontSize="16"
                    FontWeight="Bold"
                    Background="#D9534F"
                    Foreground="Blue"
                    BorderThickness="0"
                    IsEnabled="False"
                    Click="btnDeleteData_Click"/>
        </StackPanel>
    </Border>

    <!-- RIGHT PANEL -->
    <Border Grid.Column="1" CornerRadius="10" Padding="15"
            Background="LightBlue" Margin="5"
            BorderBrush="Pink" BorderThickness="1">

        <StackPanel>

            <TextBlock Text="Add / Edit"
                       FontSize="18"
                       FontWeight="Bold"
                       Margin="0,0,0,10"
                       Foreground="Black"/>

            <!-- Title -->
            <TextBlock Text="Title" Foreground="Black"/>
            <TextBox x:Name="txtTitle"
                     Height="30"
                     Margin="0,5,0,10"
                     Padding="5"
                     Background="White"
                     Foreground="Pink"
                     BorderBrush="Black" />


            <!-- Genre -->
            <TextBlock Text="Genre" Foreground="Black"/>
            <TextBox x:Name="txtGenre"
                     Height="30"
                     Margin="0,5,0,10"
                     Padding="5"
                     Background="White"
                     Foreground="Pink"
                     BorderBrush="Black"/>

            <!-- Status -->
            <TextBlock Text="Status" Foreground="Black"/>
            <ComboBox x:Name="comboBoxStatus"
                      Height="30"
                      Margin="0,5,0,10"
                      Background="Black"
                      Foreground="Black"
                      BorderBrush="Black">
                <ComboBoxItem Content="Watching"/>
                <ComboBoxItem Content="Completed"/>
                <ComboBoxItem Content="Plan to Watch"/>
            </ComboBox>

            <!-- Rating -->
            <TextBlock Text="Rating" Foreground="Black"/>

            <StackPanel Orientation="Horizontal" Margin="0,5,0,15">
                <RadioButton x:Name="rb1" Content="1 ⭐" Margin="5" Foreground="Black"/>
                <RadioButton x:Name="rb2" Content="2 ⭐" Margin="5" Foreground="Black"/>
                <RadioButton x:Name="rb3" Content="3 ⭐" Margin="5" Foreground="Black"/>
                <RadioButton x:Name="rb4" Content="4 ⭐" Margin="5" Foreground="Black"/>
                <RadioButton x:Name="rb5" Content="5 ⭐" Margin="5" Foreground="Black"/>
            </StackPanel>

            <!-- Save -->
            <Button x:Name="btnSave"
                    Content="💾 SAVE"
                    Height="45"
                    FontSize="18"
                    FontWeight="Bold"
                    Background="Green"
                    Foreground="White"
                    BorderThickness="0"
                    Click="btnSave_Click"/>
        </StackPanel>
    </Border>
</Grid>
</Window>
